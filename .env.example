# Copy to .env and fill in your key:  cp .env.example .env

# Required for AI spec extraction and world-price lookups (optional if regex is enough)
GEMINI_API_KEY=

# Model (default: gemini-3.1-flash-lite-preview)
# GEMINI_MODEL=gemini-3.1-flash-lite-preview

# AI rate limits (reduce if you hit 429 errors)
# GEMINI_MAX_WORKERS=3
# GEMINI_REQUEST_DELAY_SEC=0.5
# GEMINI_SEARCH_DELAY_SEC=1.5
# GEMINI_MAX_RETRIES=3

# Skip slow Google Search lookups for world prices / Notebookcheck (faster runs)
# ENABLE_EXTERNAL_LOOKUPS=true

# Analyzer filters (override defaults from scoring.py)
# MIN_CPU_SCORE=2500
# ADS_ANALYZE_LIMIT=500

# Database file name (default: laptops_database.db)
# DB_NAME=laptops_database.db

# Passmark benchmark cache lifetime in days (default: 7)
# PASSMARK_CACHE_DAYS=7

# Telegram digest: deals per section (default: 5) and optional quality floor.
# The floor defaults to 0 so the digest always shows the top-N best deals;
# raise TELEGRAM_MIN_VALUE_SCORE (e.g. 100) to hide weak listings.
# TELEGRAM_TOP_N=5
# TELEGRAM_MIN_VALUE_SCORE=0
